#!/usr/bin/env bash
# Shim that delegates to pre-commit via PATH lookup.
# Survives 'pre-commit install' and nix-collect-garbage.

ARGS=(hook-impl --config=.pre-commit-config.yaml --hook-type=pre-push)
HERE="$(cd "$(dirname "$0")" && pwd)"
ARGS+=(--hook-dir "$HERE" -- "$@")

exec pre-commit "${ARGS[@]}"
