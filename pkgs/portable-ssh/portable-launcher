#!/usr/bin/env bash
# portable-launcher — tiny wrapper that execs the user's portable zsh inside
# the nix-portable chroot, without going through `nix run` (which evaluates
# the flake on every invocation and takes ~95s).
#
# Runtime: prefers bwrap (kernel user namespaces, near-native speed) and
# falls back to proot (ptrace) when bwrap can't create a namespace. proot
# intercepts every syscall via ptrace, which adds large overhead to
# build-heavy workloads (e.g. bazel) — bwrap is dramatically faster when
# the host allows it. Force a runtime with NP_RUNTIME=bwrap|proot.
#
# Assumes nix-portable has been bootstrapped on this host (~/.nix-portable
# exists with proot + bwrap + emptyroot + the home-manager-generation
# closure).
#
# This script is uploaded by portable-ssh to ~/.local/bin/portable-launcher
# alongside the nix-portable binary. It's the RemoteCommand portable-ssh
# runs on interactive ssh.
set -euo pipefail

NP_DIR="${NP_LOCATION:-$HOME}/.nix-portable"
PROOT="$NP_DIR/bin/proot"
BWRAP="$NP_DIR/bin/bwrap"
EMPTYROOT="$NP_DIR/emptyroot"
NP_NIX="$NP_DIR/nix"

# Real GNU bash binary, resolved to its on-disk path under nix-portable's
# store. We bind this over /bin/sh and /bin/bash inside the chroot (see
# below) so that scripts with `#!/bin/sh` or `#!/bin/bash` shebangs run
# under a real bash — NOT nix-portable's busybox, whose `sh`/`ash` applets
# lack bash features and which has no `bash` applet at all (invoking it
# errors "applet not found").
#
# We must NOT use ~/.nix-profile/bin/bash here: that's a symlink into /nix,
# which does not exist on the bare host. Both bwrap and proot resolve bind
# SOURCE paths against the host filesystem BEFORE /nix is mounted, so the
# symlink would dangle. The real file lives under $NP_NIX/store.
# Glob the store (paths are alphanumeric+dash, so word-splitting is safe).
# Prefer bash-interactive; fall back to any bash-*.
REAL_BASH=""
for cand in "$NP_NIX"/store/*-bash-interactive-*/bin/bash "$NP_NIX"/store/*-bash-*/bin/bash; do
  if [[ -x "$cand" ]]; then
    REAL_BASH="$cand"
    break
  fi
done

if [[ ! -x "$PROOT" ]]; then
  printf 'portable-launcher: nix-portable not bootstrapped (no %s); run portable-ssh again to install\n' "$PROOT" >&2
  exec /bin/bash -l
fi

if [[ ! -L "$HOME/.nix-profile" ]]; then
  printf 'portable-launcher: home-manager not activated yet. Activating now (one-time, several minutes)...\n' >&2
  # Fall back to nix run for the first activation. After this, the
  # profile symlink exists and we use the fast path on subsequent runs.
  #
  # We let nix-portable pick its own runtime here: it probes bwrap and
  # falls back to proot on its own when user namespaces are unavailable
  # (CTC work hosts with user.max_user_namespaces=0 or SELinux denying
  # CAP_SYS_ADMIN). Force with NP_RUNTIME=bwrap|proot if needed.
  #
  # --impure is required because the CTC home-manager modules
  # (./modules/ctc -> ctc-nix) call builtins.fetchTarball without a
  # sha256 to pull a pinned nixpkgs from artifactory. Pure evaluation
  # rejects un-hashed fetches; the dev hosts solve this by passing
  # --impure to `home-manager switch` (see CTC's services.nix). We need
  # the same here for first-run activation on a remote.
  exec "$NP_DIR/bin/.."/../local/bin/nix-portable nix run --impure \
    "${PORTABLE_FLAKE_REF:-git+ssh://git@gitlab.azure.chicagotrading.com/heysej/nix.git}#activate-portable"
fi

# Bind the host filesystem into proot's chroot. /nix is the critical
# bind: it makes the home-manager-generation's nix-store paths resolve.
# Other binds (/etc, /home, /usr, /var, /run, /tmp, /proc, /sys, /dev)
# are needed so the shell inside has working PAM, networking, terminal,
# and access to your home directory.
#
# Force ~/.nix-profile/bin to the front of PATH so commands installed by
# home-manager (atuin, eza, bat, ...) win over the host's pkgsrc/devkit
# bins. The host's bash login chain typically prepends those, and we
# want our env to take precedence inside the chroot.
export PATH="$HOME/.nix-profile/bin:$PATH"

ZSH="$HOME/.nix-profile/bin/zsh"

# The directories/files to map into the chroot, as SRC:DEST pairs. /nix is
# the critical bind (makes the home-manager-generation store paths resolve).
# /bin/sh and /bin/bash are pinned to real bash (see REAL_BASH above).
binds=(
  "$NP_NIX:/nix"
  "/home:/home"
  "/etc:/etc"
  "/usr/lib:/lib"
  "/usr/lib64:/lib64"
  "/usr/bin:/bin"
  "/usr/sbin:/sbin"
  "/usr:/usr"
  "/tmp:/tmp"
  "/run:/run"
  "/var:/var"
  "/sys:/sys"
  "/ctc:/ctc"
  "$HOME:$HOME"
  "$REAL_BASH:/bin/sh"
  "$REAL_BASH:/bin/bash"
)

# Decide the runtime. NP_RUNTIME overrides; otherwise prefer bwrap and fall
# back to proot. bwrap uses kernel user namespaces (near-native speed);
# proot uses ptrace (works without privileges but adds heavy per-syscall
# overhead — painful for bazel/make). We detect bwrap by actually creating
# a namespace: hosts with user.max_user_namespaces=0 or SELinux denying
# CAP_SYS_ADMIN fail at namespace setup and we fall back to proot.
#
# The preflight execs nix-portable's STATIC busybox (musl, no shared libs).
# A dynamically-linked probe like /usr/bin/true would fail with ENOENT for
# its dynamic linker unless we bound /lib64 too — a false negative that has
# nothing to do with whether namespaces work. The static binary needs only
# itself bound, so the only thing that can fail is namespace creation.
# Bind the dest as /busybox (basename must be "busybox" for busybox to treat
# the next arg as an applet name) and run the `true` applet.
BB_STATIC="$NP_DIR/busybox/bin/busybox"
runtime="${NP_RUNTIME:-}"
if [[ -z "$runtime" ]]; then
  if [[ -x "$BWRAP" && -x "$BB_STATIC" ]] \
    && "$BWRAP" --ro-bind "$BB_STATIC" /busybox /busybox true 2>/dev/null; then
    runtime="bwrap"
  else
    runtime="proot"
  fi
fi

if [[ "$runtime" == "bwrap" ]]; then
  args=(--bind "$EMPTYROOT" / --dev-bind /dev /dev --proc /proc)
  for b in "${binds[@]}"; do
    args+=(--bind "${b%%:*}" "${b#*:}")
  done
  exec "$BWRAP" "${args[@]}" "$ZSH" -l "$@"
fi

# proot fallback.
args=(-r "$EMPTYROOT" -b /dev:/dev -b /proc:/proc)
for b in "${binds[@]}"; do
  args+=(-b "$b")
done
exec "$PROOT" "${args[@]}" "$ZSH" -l "$@"
