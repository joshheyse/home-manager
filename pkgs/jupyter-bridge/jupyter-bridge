#!/usr/bin/env bash
# jupyter-bridge - CLI for the Jupyter kernel bridge daemon
# Starts a kernel, optionally starts Lab, exposes kernel via FIFO for CLI/molten.
# Subcommands: start, stop, logs, status, exec, info

set -euo pipefail

CELL_BRIDGE_PY="@CELL_BRIDGE_PY@"

usage() {
    cat <<'EOF'
Usage: jupyter-bridge <command> [options]

Commands:
  start [--kernel NAME] [--lab]     Start kernel + bridge (add --lab for browser)
  stop                              Stop bridge, kernel, and Lab
  logs [-f]                         Show daemon logs (default: follow)
  status                            Show kernel, Lab URL, bridge PID
  exec                              Execute code from stdin on the kernel
  info                              Print CLAUDE.md-ready snippet with pipe paths

Options:
  -h, --help             Show this help
EOF
    exit 0
}

# Compute per-repo runtime directory
get_runtime_dir() {
    local repo_root
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || {
        echo "Error: not in a git repository" >&2
        exit 1
    }
    local hash
    hash="$(echo -n "${repo_root}" | sha256sum | cut -c1-8)"
    echo "/tmp/jupyter-bridge-${hash}"
}

# Auto-detect kernel name from .ipynb metadata
detect_kernel() {
    local repo_root
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"
    local kernel_name=""

    # Search for .ipynb files and extract kernel name
    while IFS= read -r -d '' nb; do
        kernel_name="$(python3 -c "
import json, sys
with open(sys.argv[1]) as f:
    nb = json.load(f)
ks = nb.get('metadata', {}).get('kernelspec', {}).get('name', '')
if ks:
    print(ks)
" "${nb}" 2>/dev/null)" || continue
        if [[ -n "${kernel_name}" ]]; then
            break
        fi
    done < <(find "${repo_root}" -maxdepth 3 -name '*.ipynb' -not -path '*/.ipynb_checkpoints/*' -print0 2>/dev/null)

    echo "${kernel_name}"
}

# Set up JUPYTER_PATH to include venv kernelspecs
setup_jupyter_path() {
    local repo_root
    repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"
    local extra_paths=""

    for venv_dir in "${repo_root}"/.venv*/share/jupyter; do
        if [[ -d "${venv_dir}" ]]; then
            if [[ -n "${extra_paths}" ]]; then
                extra_paths="${extra_paths}:${venv_dir}"
            else
                extra_paths="${venv_dir}"
            fi
        fi
    done

    if [[ -n "${extra_paths}" ]]; then
        if [[ -n "${JUPYTER_PATH:-}" ]]; then
            export JUPYTER_PATH="${extra_paths}:${JUPYTER_PATH}"
        else
            export JUPYTER_PATH="${extra_paths}"
        fi
    fi
}

cmd_start() {
    local kernel=""
    local start_lab=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --kernel) kernel="$2"; shift 2 ;;
            --lab) start_lab=true; shift ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done

    local runtime_dir
    runtime_dir="$(get_runtime_dir)"

    # Always clean up previous state — idempotent restart
    if [[ -d "${runtime_dir}" ]]; then
        cmd_stop
    fi

    # Auto-detect kernel if not specified
    if [[ -z "${kernel}" ]]; then
        kernel="$(detect_kernel)"
        if [[ -z "${kernel}" ]]; then
            echo "Error: could not auto-detect kernel name. Use --kernel NAME" >&2
            exit 1
        fi
        echo "Auto-detected kernel: ${kernel}"
    fi

    # Create runtime directory and FIFO
    mkdir -p "${runtime_dir}"
    mkfifo "${runtime_dir}/pipe.in"

    # Set up JUPYTER_PATH for venv kernelspecs
    setup_jupyter_path

    # Launch cell-bridge daemon (starts the kernel)
    python3 "${CELL_BRIDGE_PY}" \
        --runtime-dir "${runtime_dir}" \
        --kernel "${kernel}" &
    local bridge_pid=$!
    echo "${bridge_pid}" > "${runtime_dir}/pid"

    # Wait for kernel to be ready (connection file appears)
    local elapsed=0
    while [[ ! -f "${runtime_dir}/connection" ]]; do
        sleep 0.5
        elapsed=$((elapsed + 1))
        if [[ ${elapsed} -ge 60 ]]; then
            echo "Error: timed out waiting for kernel to start" >&2
            kill "${bridge_pid}" 2>/dev/null || true
            rm -rf "${runtime_dir}"
            exit 1
        fi
        if ! kill -0 "${bridge_pid}" 2>/dev/null; then
            echo "Error: bridge exited unexpectedly. Check ${runtime_dir}/bridge.log" >&2
            cat "${runtime_dir}/bridge.log" 2>/dev/null || true
            rm -rf "${runtime_dir}"
            exit 1
        fi
    done

    local connection_file
    connection_file="$(cat "${runtime_dir}/connection")"
    local kernel_name
    kernel_name="$(basename "${connection_file}" .json)"

    echo "Kernel ready: ${kernel_name}"
    echo "Bridge running (PID ${bridge_pid})"

    # Optionally start Jupyter Lab
    if [[ "${start_lab}" == true ]]; then
        local repo_root
        repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"
        jupyter lab --no-browser --ip=0.0.0.0 --notebook-dir="${repo_root}/notebooks" \
            >> "${runtime_dir}/bridge.log" 2>&1 &
        local lab_pid=$!
        echo "${lab_pid}" > "${runtime_dir}/lab.pid"

        # Wait for Lab URL
        local lab_url=""
        elapsed=0
        while [[ -z "${lab_url}" ]]; do
            sleep 1
            elapsed=$((elapsed + 1))
            if [[ ${elapsed} -ge 30 ]]; then
                echo "Warning: Lab did not start within 30s (bridge still works)" >&2
                break
            fi
            if ! kill -0 "${lab_pid}" 2>/dev/null; then
                echo "Warning: Lab exited unexpectedly (bridge still works)" >&2
                break
            fi
            lab_url="$(grep -oP 'http://[^ ]*token=[^ ]*' "${runtime_dir}/bridge.log" 2>/dev/null | head -1)" || true
        done

        if [[ -n "${lab_url}" ]]; then
            echo "${lab_url}" > "${runtime_dir}/lab.url"
            echo "Lab: ${lab_url}"
        fi
    fi

    echo "Exec via: echo \"print(42)\" | jupyter-bridge exec"
}

cmd_stop() {
    local runtime_dir
    runtime_dir="$(get_runtime_dir)"

    local stopped_something=false

    # Stop bridge daemon (also kills the kernel if bridge-owned)
    if [[ -f "${runtime_dir}/pid" ]]; then
        local pid
        pid="$(cat "${runtime_dir}/pid")"
        if kill -0 "${pid}" 2>/dev/null; then
            kill "${pid}"
            echo "Stopped bridge (PID ${pid})"
            stopped_something=true
        fi
    fi

    # Stop Jupyter Lab
    if [[ -f "${runtime_dir}/lab.pid" ]]; then
        local lab_pid
        lab_pid="$(cat "${runtime_dir}/lab.pid")"
        if kill -0 "${lab_pid}" 2>/dev/null; then
            kill "${lab_pid}"
            echo "Stopped Jupyter Lab (PID ${lab_pid})"
            stopped_something=true
        fi
    fi

    if [[ "${stopped_something}" == false ]]; then
        echo "Nothing running"
    fi

    rm -rf "${runtime_dir}"
}

cmd_logs() {
    local follow=1
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f|--follow) follow=1; shift ;;
            --no-follow) follow=0; shift ;;
            *) shift ;;
        esac
    done

    local runtime_dir
    runtime_dir="$(get_runtime_dir)"
    local log_file="${runtime_dir}/bridge.log"

    if [[ ! -f "${log_file}" ]]; then
        echo "No log file found at ${log_file}" >&2
        exit 1
    fi

    if [[ "${follow}" -eq 1 ]]; then
        tail -f "${log_file}"
    else
        cat "${log_file}"
    fi
}

cmd_status() {
    local runtime_dir
    runtime_dir="$(get_runtime_dir)"

    if [[ ! -d "${runtime_dir}" ]]; then
        echo "Not running"
        exit 1
    fi

    echo "Runtime dir: ${runtime_dir}"

    # Bridge status
    if [[ -f "${runtime_dir}/pid" ]]; then
        local pid
        pid="$(cat "${runtime_dir}/pid")"
        if kill -0 "${pid}" 2>/dev/null; then
            echo "Bridge:      running (PID ${pid})"
        else
            echo "Bridge:      stopped (stale PID ${pid})"
        fi
    else
        echo "Bridge:      not started"
    fi

    # Connection file
    if [[ -f "${runtime_dir}/connection" ]]; then
        echo "Connection:  $(cat "${runtime_dir}/connection")"
    else
        echo "Connection:  no kernel"
    fi

    # Lab status
    if [[ -f "${runtime_dir}/lab.pid" ]]; then
        local lab_pid
        lab_pid="$(cat "${runtime_dir}/lab.pid")"
        if kill -0 "${lab_pid}" 2>/dev/null; then
            echo "Lab:         running (PID ${lab_pid})"
        else
            echo "Lab:         stopped (stale PID ${lab_pid})"
        fi
    else
        echo "Lab:         not started"
    fi

    # Lab URL
    if [[ -f "${runtime_dir}/lab.url" ]]; then
        echo "Lab URL:     $(cat "${runtime_dir}/lab.url")"
    fi

    echo "Pipe:        ${runtime_dir}/pipe.in"
    echo "Output:      ${runtime_dir}/out.json"
    echo "Log:         ${runtime_dir}/bridge.log"
}

cmd_exec() {
    local runtime_dir
    runtime_dir="$(get_runtime_dir)"

    if [[ ! -p "${runtime_dir}/pipe.in" ]]; then
        echo "Error: bridge not running (no FIFO at ${runtime_dir}/pipe.in)" >&2
        exit 1
    fi

    # Remove old output
    rm -f "${runtime_dir}/out.json"

    # Read code from stdin and write to FIFO
    cat > "${runtime_dir}/pipe.in"

    # Poll for output (timeout after 120s)
    local elapsed=0
    while [[ ! -f "${runtime_dir}/out.json" ]]; do
        sleep 0.1
        elapsed=$((elapsed + 1))
        if [[ ${elapsed} -ge 1200 ]]; then
            echo '{"status": "error", "error": "timeout waiting for output"}' >&2
            exit 1
        fi
    done

    cat "${runtime_dir}/out.json"
}

cmd_info() {
    local runtime_dir
    runtime_dir="$(get_runtime_dir)"

    cat <<EOF
## Jupyter Bridge

A kernel bridge is available for executing Python code on the project's Jupyter kernel.

\`\`\`bash
# Execute code on the kernel
echo "print(42)" | jupyter-bridge exec

# Multi-line execution
jupyter-bridge exec <<'PYEOF'
import numpy as np
arr = np.arange(10)
print(arr.mean())
PYEOF
\`\`\`

Runtime directory: \`${runtime_dir}\`
EOF
}

# Main dispatch
if [[ $# -eq 0 ]]; then
    usage
fi

case "$1" in
    start)  shift; cmd_start "$@" ;;
    stop)   shift; cmd_stop "$@" ;;
    logs)   shift; cmd_logs "$@" ;;
    status) shift; cmd_status "$@" ;;
    exec)   shift; cmd_exec "$@" ;;
    info)   shift; cmd_info "$@" ;;
    -h|--help) usage ;;
    *) echo "Unknown command: $1" >&2; usage ;;
esac
